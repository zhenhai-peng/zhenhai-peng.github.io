---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import Typewriter from '../../components/Typewriter.astro';
import { getCollection } from 'astro:content';
import { t, getPostSlug } from '../../i18n/utils';

const lang = 'zh' as const;

const allPosts = await getCollection('blog', ({ slug, data }) => {
  return slug.endsWith('/zh') && !data.draft;
});

const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const roles = ['软件工程师', '全栈开发者', '开源爱好者', '问题解决者'];
const bioLines = [
  '我构建互联网产品，同时记录学习路上的所思所想。',
  '热爱简洁的代码、精心的设计，喜欢深入研究有趣的技术问题。',
];
---

<BaseLayout
  title="Zhenhai Peng — 软件工程师"
  description="Zhenhai Peng 的个人网站和博客"
  lang={lang}
  translationPath="/en/"
>
  <!-- ═══════════ HERO ═══════════ -->
  <section class="hero-grid relative min-h-[92vh] pt-16">
    <div class="mx-auto flex min-h-[calc(92vh-4rem)] max-w-7xl flex-col justify-center px-4 py-20 lg:flex-row lg:items-center lg:gap-16 lg:px-8">

      <!-- Left: text -->
      <div class="flex-1">
        <!-- Role badge -->
        <div
          class="animate-fade-up mb-6 inline-flex items-center gap-2 rounded-full border border-gold/30 bg-blue-50 px-4 py-1.5"
          style="animation-delay:0ms"
        >
          <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-gold"></span>
          <span class="font-mono text-xs font-semibold tracking-wide text-gold-dim">
            <Typewriter id="role-tw-zh" phrases={roles} speed={80} deleteSpeed={40} pauseTime={2000} loop />
          </span>
        </div>

        <!-- Name -->
        <h1
          class="animate-fade-up font-display font-extrabold leading-[1.2] tracking-tight"
          style="animation-delay:80ms"
        >
          <span class="block text-xl font-medium text-ink-400 mb-4">{t(lang, 'home.greeting')}</span>
          <span class="block text-6xl text-gradient md:text-7xl lg:text-8xl">Zhenhai Peng</span>
        </h1>

        <!-- Bio typewriter -->
        <p
          class="animate-fade-up mt-6 min-h-[4rem] max-w-md text-lg leading-relaxed text-ink-400 md:text-xl"
          style="animation-delay:200ms"
        >
          <Typewriter
            id="bio-tw-zh"
            phrases={bioLines}
            speed={60}
            deleteSpeed={30}
            pauseTime={3000}
            loop
            class="text-ink-400"
          />
        </p>

        <!-- CTAs -->
        <div
          class="animate-fade-up mt-8 flex flex-wrap gap-3"
          style="animation-delay:320ms"
        >
          <a
            href={`/${lang}/blog/`}
            class="btn-magnetic inline-flex items-center gap-2 rounded-xl bg-gold px-6 py-3 font-display text-sm font-semibold text-white shadow-md shadow-blue-200/60 transition-colors hover:bg-gold-dim"
          >
            {t(lang, 'home.cta_blog')} →
          </a>
          <a
            href="https://drive.google.com/file/d/1p6bUCqgVdCrq6sdmUdh0gFfJGwzq8bqN/view?usp=sharing"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-magnetic inline-flex items-center gap-2 rounded-xl border border-ink-700 bg-white px-6 py-3 font-display text-sm font-semibold text-ink-300 shadow-sm transition-all hover:border-ink-500 hover:text-ink-100 hover:shadow-md"
          >
            我的简历
          </a>
        </div>

        <div class="mt-14 hidden items-center gap-3 lg:flex">
          <div class="h-px w-8 bg-ink-700"></div>
          <span class="font-mono text-[10px] tracking-[0.3em] uppercase text-ink-600">scroll</span>
        </div>
      </div>

      <!-- Right: Terminal card -->
      <div
        class="animate-fade-in float-card mt-12 hidden lg:mt-0 lg:block lg:w-[420px] xl:w-[460px]"
        style="animation-delay:500ms"
      >
        <div class="overflow-hidden rounded-2xl border border-zinc-700/60 shadow-2xl shadow-blue-100/40" style="background:#1e1e2e">
          <div class="flex items-center gap-2 border-b border-zinc-700/60 px-4 py-3" style="background:#181825">
            <span class="h-3 w-3 rounded-full" style="background:#ff5f56"></span>
            <span class="h-3 w-3 rounded-full" style="background:#ffbd2e"></span>
            <span class="h-3 w-3 rounded-full" style="background:#27c93f"></span>
            <span class="ml-3 font-mono text-xs" style="color:#6c7086">developer.ts</span>
          </div>
          <pre class="overflow-x-auto p-6 font-mono text-[13px] leading-relaxed" style="color:#cdd6f4"><code><span style="color:#89b4fa">const</span> <span style="color:#cdd6f4">developer</span> <span style="color:#89dceb">=</span> <span style="color:#cdd6f4">&#123;</span>
  <span style="color:#89dceb">name</span><span style="color:#cdd6f4">:</span>      <span style="color:#a6e3a1">"Zhenhai Peng"</span><span style="color:#cdd6f4">,</span>
  <span style="color:#89dceb">role</span><span style="color:#cdd6f4">:</span>      <span style="color:#a6e3a1">"Software Engineer"</span><span style="color:#cdd6f4">,</span>
  <span style="color:#89dceb">location</span><span style="color:#cdd6f4">:</span>  <span style="color:#a6e3a1">"San Francisco, CA"</span><span style="color:#cdd6f4">,</span>
  <span style="color:#89dceb">stack</span><span style="color:#cdd6f4">:</span>     <span style="color:#cdd6f4">[</span>
    <span style="color:#a6e3a1">"Java"</span><span style="color:#cdd6f4">,</span>        <span style="color:#a6e3a1">"Python"</span><span style="color:#cdd6f4">,</span>
    <span style="color:#a6e3a1">"TypeScript"</span><span style="color:#cdd6f4">,</span>  <span style="color:#a6e3a1">"React"</span><span style="color:#cdd6f4">,</span>
    <span style="color:#a6e3a1">"MySQL"</span><span style="color:#cdd6f4">,</span>       <span style="color:#a6e3a1">"Redis"</span><span style="color:#cdd6f4">,</span>
    <span style="color:#a6e3a1">"AI Agent"</span><span style="color:#cdd6f4">,</span>   <span style="color:#a6e3a1">"Kafka"</span>
  <span style="color:#cdd6f4">],</span>
  <span style="color:#89dceb">passions</span><span style="color:#cdd6f4">:</span>  <span style="color:#cdd6f4">[</span><span style="color:#a6e3a1">"clean code"</span><span style="color:#cdd6f4">,</span> <span style="color:#a6e3a1">"AI Native"</span><span style="color:#cdd6f4">],</span>
  <span style="color:#89dceb">available</span><span style="color:#cdd6f4">:</span> <span style="color:#fab387">true</span><span style="color:#cdd6f4">,</span>
<span style="color:#cdd6f4">&#125;;</span>

<span style="color:#6c7086">// 持续学习中...</span>
<span style="color:#89b4fa">export default</span> developer<span style="color:#cdd6f4">;</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <div class="h-px bg-gradient-to-r from-transparent via-ink-700 to-transparent"></div>
  </div>

  <!-- ═══════════ 工作与教育经历 ═══════════ -->
  <section class="mx-auto max-w-7xl px-4 py-24 lg:px-6">
    <div class="mb-12" data-reveal>
      <p class="mb-1 font-mono text-xs font-medium tracking-[0.2em] uppercase text-gold-dim">背景经历</p>
      <h2 class="font-display text-3xl font-bold tracking-tight text-ink-100">工作与教育经历</h2>
    </div>

    <div class="grid gap-10 lg:grid-cols-2">
      <!-- 工作经历 -->
      <div data-reveal>
        <div class="mb-6 flex items-center gap-3">
          <span class="font-mono text-xs font-semibold tracking-[0.2em] uppercase text-ink-500">工作经历</span>
          <div class="h-px flex-1 bg-ink-700"></div>
        </div>
        <div class="space-y-4">
          <!-- Alibaba Group -->
          <div class="flex gap-4 rounded-2xl border border-ink-700/40 bg-white p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-ink-700/30 bg-white p-1.5">
              <img src="/alibaba.png" alt="阿里巴巴集团" class="h-full w-full object-contain" />
            </div>
            <div class="min-w-0 flex-1">
              <div class="font-display text-base font-semibold text-ink-100">阿里巴巴集团</div>
              <div class="mt-0.5 font-mono text-sm text-ink-400">软件工程师实习生</div>
              <div class="mt-2 font-mono text-xs text-ink-600">2025年5月 – 2025年8月</div>
            </div>
          </div>
          <!-- Bosch -->
          <div class="flex gap-4 rounded-2xl border border-ink-700/40 bg-white p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-ink-700/30 bg-white p-1.5">
              <img src="/bosch.png" alt="博世" class="h-full w-full object-contain" />
            </div>
            <div class="min-w-0 flex-1">
              <div class="font-display text-base font-semibold text-ink-100">博世</div>
              <div class="mt-0.5 font-mono text-sm text-ink-400">软件工程师实习生</div>
              <div class="mt-2 font-mono text-xs text-ink-600">2024年6月 – 2024年8月</div>
            </div>
          </div>
        </div>
      </div>

      <!-- 教育背景 -->
      <div data-reveal data-delay="150">
        <div class="mb-6 flex items-center gap-3">
          <span class="font-mono text-xs font-semibold tracking-[0.2em] uppercase text-ink-500">教育背景</span>
          <div class="h-px flex-1 bg-ink-700"></div>
        </div>
        <div class="space-y-4">
          <!-- Northeastern University -->
          <div class="flex gap-4 rounded-2xl border border-ink-700/40 bg-white p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-ink-700/30 bg-white p-1.5">
              <img src="/northeastern.png" alt="美国东北大学" class="h-full w-full object-contain" />
            </div>
            <div class="min-w-0 flex-1">
              <div class="font-display text-base font-semibold text-ink-100">美国东北大学</div>
              <div class="mt-0.5 font-mono text-sm text-ink-400">计算机科学理学硕士</div>
              <div class="mt-2 font-mono text-xs text-ink-600">2024年9月 – 2026年5月</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <div class="h-px bg-gradient-to-r from-transparent via-ink-700 to-transparent"></div>
  </div>

  <!-- ═══════════ RECENT POSTS ═══════════ -->
  {recentPosts.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 py-24 lg:px-6">
      <div class="mb-12 flex items-end justify-between" data-reveal>
        <div>
          <p class="mb-1 font-mono text-xs font-medium tracking-[0.2em] uppercase text-gold-dim">Latest Writing</p>
          <h2 class="font-display text-3xl font-bold tracking-tight text-ink-100">
            {t(lang, 'home.latest_posts')}
          </h2>
        </div>
        <a
          href={`/${lang}/blog/`}
          class="hidden items-center gap-1 font-mono text-xs text-ink-500 transition-colors hover:text-gold sm:flex"
        >
          {t(lang, 'home.all_posts')} →
        </a>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {recentPosts.map((post, i) => {
          const slug = getPostSlug(post.slug);
          return (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              href={`/${lang}/blog/${slug}/`}
              date={post.data.pubDate}
              tags={post.data.tags}
              lang={lang}
              delay={i * 120}
            />
          );
        })}
      </div>
    </section>
  )}
</BaseLayout>
