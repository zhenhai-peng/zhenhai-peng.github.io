---
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  href: string;
  date: Date;
  tags?: string[];
  lang: Lang;
  delay?: number;
}

const { title, description, href, date, tags = [], lang, delay = 0 } = Astro.props;

const formattedDate = date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article
  class="card-3d group relative overflow-hidden rounded-2xl border border-ink-700 bg-ink-800 p-6 shadow-sm"
  data-reveal
  data-delay={delay}
>
  <a href={href} class="absolute inset-0 z-10" aria-label={title}></a>

  <!-- Hover shimmer -->
  <div class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 transition-opacity duration-300 group-hover:opacity-100"
       style="background: radial-gradient(circle at var(--mx,50%) var(--my,50%), rgba(37,99,235,0.06) 0%, transparent 60%)">
  </div>

  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <time
        datetime={date.toISOString()}
        class="mb-3 block font-mono text-[11px] font-medium tracking-wider text-gold-dim"
      >
        {formattedDate}
      </time>

      <h2 class="mb-2 font-display text-lg font-bold leading-snug tracking-tight text-ink-100 transition-colors duration-200 group-hover:text-gold">
        {title}
      </h2>

      <p class="line-clamp-2 text-sm leading-relaxed text-ink-500">
        {description}
      </p>
    </div>

    <div class="mt-0.5 shrink-0">
      <span class="flex h-8 w-8 items-center justify-center rounded-full border border-ink-700 text-sm text-ink-600 transition-all duration-200 group-hover:border-gold group-hover:bg-blue-50 group-hover:text-gold group-hover:scale-110">
        →
      </span>
    </div>
  </div>

  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {tags.map(tag => (
        <span class="rounded-md border border-ink-700 bg-ink-900 px-2 py-0.5 font-mono text-[10px] font-medium text-ink-500">
          #{tag}
        </span>
      ))}
    </div>
  )}
</article>

<script>
  // Track mouse position per card for the shimmer
  document.querySelectorAll<HTMLElement>('.card-3d').forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const r = card.getBoundingClientRect();
      card.style.setProperty('--mx', ((e.clientX - r.left) / r.width  * 100) + '%');
      card.style.setProperty('--my', ((e.clientY - r.top)  / r.height * 100) + '%');
    });
  });
</script>
