---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  lang: Lang;
  translationPath: string | null;
}

const { lang, translationPath } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: `/${lang}/`, label: t(lang, 'nav.home') },
  { href: `/${lang}/blog/`, label: t(lang, 'nav.blog') },
];

const isActive = (href: string) => {
  if (href === `/${lang}/`) return currentPath === `/${lang}/`;
  return currentPath.startsWith(href);
};

const otherLang: Lang = lang === 'en' ? 'zh' : 'en';
const otherLangLabel = lang === 'en' ? '中文' : 'EN';
const currentLangLabel = lang === 'en' ? 'EN' : '中文';
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-ink-700 bg-white/90 backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 lg:px-6">

    <!-- Logo -->
    <a
      href={`/${lang}/`}
      class="font-display text-xl font-bold tracking-tight text-ink-100 transition-colors hover:text-gold"
    >
      Zhenhai Peng
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden items-center gap-8 md:flex">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`font-mono text-base tracking-[0.15em] uppercase transition-colors ${
              isActive(href)
                ? 'text-ink-100 font-medium'
                : 'text-ink-500 hover:text-ink-300'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Language Switcher + Mobile Toggle -->
    <div class="flex items-center gap-5">

      <!-- Language Switcher -->
      <div class="flex items-center gap-2.5 rounded-full border border-ink-700 bg-ink-900 px-3 py-1">
        <span class="font-mono text-base font-semibold text-gold">{currentLangLabel}</span>
        <span class="h-3 w-px bg-ink-700"></span>
        {translationPath ? (
          <a
            href={translationPath}
            class="font-mono text-base text-ink-500 transition-colors hover:text-ink-300"
            title={`Switch to ${otherLangLabel}`}
          >
            {otherLangLabel}
          </a>
        ) : (
          <span
            class="cursor-not-allowed font-mono text-base text-ink-600"
            title={t(lang, 'blog.no_translation')}
          >
            {otherLangLabel}
          </span>
        )}
      </div>

      <!-- Mobile Toggle -->
      <button
        id="mobile-toggle"
        class="text-ink-500 transition-colors hover:text-ink-100 md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M3 5H17M3 10H17M3 15H17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 20 20" fill="none" class="hidden">
          <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden border-t border-ink-700 bg-white md:hidden">
    <ul class="space-y-1 px-6 py-4">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`block rounded-lg px-3 py-2.5 font-mono text-sm tracking-[0.15em] uppercase transition-colors ${
              isActive(href)
                ? 'text-ink-100 font-medium bg-ink-900'
                : 'text-ink-500 hover:text-ink-300 hover:bg-ink-900'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
